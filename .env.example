# JoyClaw 配置文件示例
# 复制此文件为 .env 并填写您的配置

# ============================================
# LLM 提供商配置
# ============================================

# LLM 提供商选择 (openai, deepseek, zhipu, moonshot, ollama, custom)
LLM_PROVIDER=deepseek

# 通用 LLM 配置 (适用于所有提供商)
# 注意: LLM_API_KEY, LLM_BASE_URL, LLM_MODEL 优先级高于预设配置
LLM_API_KEY=your_api_key_here
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# ============================================
# 各提供商预设配置示例
# ============================================

# OpenAI
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-xxxxxxxxxxxxx
# LLM_MODEL=gpt-4o-mini

# DeepSeek (默认)
# LLM_PROVIDER=deepseek
# LLM_API_KEY=sk-xxxxxxxxxxxxx
# LLM_MODEL=deepseek-chat

# 智谱 AI (GLM)
# LLM_PROVIDER=zhipu
# LLM_API_KEY=xxxxxxxxxxxxx
# LLM_MODEL=glm-4

# 月之暗面 (Moonshot)
# LLM_PROVIDER=moonshot
# LLM_API_KEY=sk-xxxxxxxxxxxxx
# LLM_MODEL=moonshot-v1-8k

# Ollama (本地部署)
# LLM_PROVIDER=ollama
# LLM_API_KEY=ollama  # Ollama 不需要真实 key
# LLM_MODEL=llama2
# LLM_BASE_URL=http://localhost:11434/v1

# ============================================
# 兼容旧配置 (已废弃,建议迁移到新配置)
# ============================================
# DEEPSEEK_API_KEY=your_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# ============================================
# 安全配置
# ============================================

# 允许执行的命令列表 (逗号分隔)
ALLOWED_COMMANDS=ls,cat,echo,pwd,whoami,date

# 最大文件大小 (字节)
MAX_FILE_SIZE=1048576
